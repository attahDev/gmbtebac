// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstname        String
  lastname         String
  organization     String?
  role             UserRole? // 👈 Uses enum now!
  isVerified       Boolean   @default(false)
  agreedToTerms    Boolean   @default(false)
  subscribedToNews Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  otps                 Otp[]
  refreshTokens        RefreshToken[]
  verificationSessions VerificationSession[]
  mentorChats          MentorChat[]
  businessPlans        BusinessPlan[]

  brandAssets BrandAsset[]
    chatSessions         ChatSession[]

  mentorConnections MentorConnection[]
  courseProgress    CourseProgress[]
  eventAttendance   EventAttendance[]
  userBadges        UserBadge[]
  activityLogs      ActivityLog[]

  @@map("users")
}

enum UserRole {
  STUDENT
  PROFESSIONAL
  ENGINEER
  ADMIN
  OTHER
}

model Otp {
  id        String   @id @default(uuid())
  code      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  useCase   UseCase

  createdAt DateTime @default(now())

  @@map("otps")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model VerificationSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime

  @@map("verification_sessions")
}

enum UseCase {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model NewsletterSubscription {
  id        String  @id @default(uuid())
  firstName String
  email     String  @unique
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("newsletter_subscriptions")
}

model PartnerRequest {
  id               String  @id @default(uuid())
  fullName         String
  organizationName String
  email            String
  message          String
  wantsSponsorship Boolean @default(false)

  status PartnerRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partner_requests")
}

enum PartnerRequestStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model ContactMessage {
  id               String  @id @default(uuid())
  fullName         String
  email            String
  subject          String
  message          String
  wantsPartnership Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}

model MentorChat {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages MentorMessage[]

  @@map("mentor_chats")
}

model MentorMessage {
  id     String     @id @default(uuid())
  chatId String
  chat   MentorChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role    MentorMessageRole
  content String

  createdAt DateTime @default(now())

  @@map("mentor_messages")
}

enum MentorMessageRole {
  USER
  ASSISTANT
}

model BusinessPlan {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessIdea    String
  industry        String
  targetAudience  String
  skills          String
  budget          String
  location        String
  experienceLevel String
  goal            String

  aiResponse Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_plans")
}

enum BrandAssetType {
  LOGO
  BUSINESS_CARD
  LETTERHEAD
  EMAIL_SIGNATURE
  INVOICE
  QUOTATION
  COMPANY_PROFILE
  CAPABILITY_STATEMENT
  BRAND_GUIDELINES
}

enum BrandAssetStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model BrandAsset {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  externalAssetId String? @unique
  jobId           String?

  assetType BrandAssetType
  status    BrandAssetStatus @default(PENDING)

  version       Int     @default(1)
  parentAssetId String?

  inputsSnapshot Json
  aiContent      Json?
  rawResponse    Json?

  pdfUrl            String?
  docxUrl           String?
  pngUrl            String?
  svgLightUrl       String?
  svgDarkUrl        String?
  pngTransparentUrl String?

  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([assetType])
  @@index([status])
  @@map("brand_assets")
}


model ChatSession {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  visitorType ChatVisitorType @default(UNKNOWN)
  status      ChatSessionStatus @default(OPEN)

  title String?

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([visitorType])
  @@index([status])
  @@map("chat_sessions")
}

model ChatMessage {
  id String @id @default(uuid())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  sender  ChatSender
  content String

  aiStatus   String?
  aiRawReply Json?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

enum ChatVisitorType {
  STUDENT
  MENTOR
  PARTNER
  UNKNOWN
}

enum ChatSessionStatus {
  OPEN
  CLOSED
  ESCALATED
}

enum ChatSender {
  USER
  BOT
}
// ---------------------------------------------------------------------------
// Engagement models — mentors, opportunities, courses, events, badges,
// activity feed, community spotlight. Added to back the Student Dashboard,
// which previously rendered hardcoded numbers with no backing data.
// ---------------------------------------------------------------------------

model Mentor {
  id        String  @id @default(uuid())
  name      String
  role      String
  company   String?
  avatarUrl String?
  bio       String?
  skills    String[]
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connections MentorConnection[]

  @@index([isActive])
  @@map("mentors")
}

enum MentorConnectionStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
}

model MentorConnection {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentorId String
  mentor   Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  status            MentorConnectionStatus @default(PENDING)
  sessionsCompleted Int                    @default(0)
  nextSessionAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mentorId])
  @@index([userId])
  @@map("mentor_connections")
}

model Opportunity {
  id       String    @id @default(uuid())
  title    String
  company  String
  location String?
  type     String?
  url      String?
  postedAt DateTime  @default(now())
  isActive Boolean   @default(true)

  @@index([isActive])
  @@map("opportunities")
}

model Course {
  id          String  @id @default(uuid())
  // Stable, human-readable identifier used in frontend URLs
  // (/dashboard/green-impact/:courseSlug). Generated from title on create.
  slug        String  @unique
  title       String
  description String?
  category    String?
  // Extra display fields that used to live hardcoded in
  // sustainabilityCourses.ts (image, duration, contactHours, mode, level,
  // certificateAvailable, learningOutcomes, shortDescription). Kept as JSON
  // instead of a wall of nullable columns since it's display metadata, not
  // relational data — same reasoning as Module.content.
  metadata Json?
  // NOTE: totalModules is now a DENORMALIZED CACHE, kept in sync by the
  // modules service whenever a Module is created/deleted for this course.
  // The source of truth is COUNT(modules). Never set this by hand — it
  // exists so list views don't need a join/count on every request.
  totalModules Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress CourseProgress[]
  modules  Module[]

  @@index([isActive])
  @@map("courses")
}

model Module {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Stable identifier for /dashboard/green-impact/:courseSlug/:lessonSlug.
  // Unique per-course (not globally), generated from title on create.
  slug    String
  title   String
  // Rich content — store structured JSON (sections/paragraphs/media) so the
  // frontend can render it the same way it rendered the old hardcoded
  // sustainabilityCourses.ts data, just sourced from the DB instead.
  content Json
  order   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, slug])
  @@index([courseId])
  @@index([courseId, order])
  @@map("modules")
}

model CourseProgress {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  completedModules Int     @default(0)
  isCompleted      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@map("course_progress")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  isActive    Boolean   @default(true)

  createdAt DateTime @default(now())

  attendees EventAttendance[]

  @@index([isActive])
  @@index([startsAt])
  @@map("events")
}

model EventAttendance {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  status String @default("REGISTERED")

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId])
  @@map("event_attendance")
}

model Badge {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  icon        String?

  createdAt DateTime @default(now())

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model ActivityLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  message String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model SpotlightStory {
  id          String  @id @default(uuid())
  title       String
  description String
  authorName  String
  authorRole  String
  avatarColor String? @default("bg-red-600")
  imageUrl    String?
  likes       Int     @default(0)
  comments    Int     @default(0)
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([isPublished])
  @@map("spotlight_stories")
}
